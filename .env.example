# ---------------------------------------------------------------------------
# Finance Copilot — environment variables
#
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# All variables are loaded by `finance_copilot.config.Settings`.
# ---------------------------------------------------------------------------

# Runtime environment: development | staging | production
# Controls log format (pretty in development, JSON elsewhere) and validation strictness.
APP_ENV=development

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Optional: emit logs as JSON regardless of APP_ENV (true/false).
# Leave unset to let APP_ENV decide.
# LOG_JSON=false

# ---------------------------------------------------------------------------
# GoCardless Bank Account Data API
# Create an application at https://bankaccountdata.gocardless.com/ and copy
# the Secret ID and Secret Key here.
# ---------------------------------------------------------------------------
GOCARDLESS_SECRET_ID=replace-me
GOCARDLESS_SECRET_KEY=replace-me

# Base URL for the GoCardless Bank Account Data API. The default is correct
# for production; override only for testing against a mock server.
GOCARDLESS_BASE_URL=https://bankaccountdata.gocardless.com/api/v2

# ---------------------------------------------------------------------------
# Local storage
# Directory where ingested data, SQLite database, and cached tokens are
# written. Relative paths are resolved against the project root.
# ---------------------------------------------------------------------------
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/finance_copilot.db
